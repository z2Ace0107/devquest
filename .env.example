# DevQuest — 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# ── LLM Provider ───────────────────────────────────────────────
# 主 Provider: DeepSeek V4 Flash（通过 opencode.ai）
LLM_PRIMARY_API_KEY=sk-your-opencode-key
LLM_PRIMARY_BASE_URL=https://opencode.ai/zen/go/v1
LLM_PRIMARY_MODEL=deepseek-v4-flash

# 备用 Provider: 旧 DeepSeek API（主 Provider 不可用时自动降级）
LLM_FALLBACK_API_KEY=sk-your-deepseek-key
LLM_FALLBACK_BASE_URL=https://api.deepseek.com/v1
LLM_FALLBACK_MODEL=deepseek-chat

# 阿里百炼 (Embedding)
EMBEDDING_API_KEY=sk-your-aliyun-key
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 飞书推送（可选，不配也能用 DevQuest）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-token

# 飞书文档（可选，通过官方 lark-cli 推送编译文档到飞书）
# 安装: npx @larksuite/cli@latest install
# 登录: lark-cli config init && lark-cli auth login --recommend

# Claude Session 数据源（可选）
CLAUDE_SESSIONS_DIR=C:/Users/<你的用户名>/.claude/projects
WATCH_PROJECTS=e--develop-claude
